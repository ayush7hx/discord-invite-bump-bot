# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# ─── ZARURI: Auto /bump ke liye apna Discord User Token ───────
# Bina is token ke bot slash commands trigger nahi kar sakta
# Kaise milega: Neeche README mein dekho
USER_TOKEN=your_discord_user_token_here

# Channel ID where invite logs will be sent
INVITE_CHANNEL_ID=123456789012345678

# Channel ID where the bot will auto-bump (and send bump messages)
BUMP_CHANNEL_ID=123456789012345678

# Extra text-based bump commands (comma separated)
# BUMP_TEXT_COMMANDS=!d bump,b!bump
BUMP_TEXT_COMMANDS=
