# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where invite logs will be sent
INVITE_CHANNEL_ID=123456789012345678

# Channel ID where bump reminders will be sent (if not auto-detected)
BUMP_CHANNEL_ID=123456789012345678

# (Optional) Role ID to ping for bump reminders
BUMP_ROLE_ID=123456789012345678
