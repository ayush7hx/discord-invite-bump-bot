# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where invite logs will be sent
INVITE_CHANNEL_ID=123456789012345678

# Channel ID where the bot will auto-bump (and send bump messages)
BUMP_CHANNEL_ID=123456789012345678

# ─── AUTO BUMP SETTINGS ───────────────────────────────────────

# Enable/disable Disboard /bump auto trigger (true/false)
DISBOARD_AUTO_BUMP=true

# Extra text-based bump commands (comma separated)
# Example for bots that still use prefix commands:
# BUMP_TEXT_COMMANDS=!d bump,b!bump,;;bump
BUMP_TEXT_COMMANDS=
